{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Live Tracking State",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "hrafnsyn_tracks_active_total{instance=~\"$instance\"}", "legendFormat": "" }],
      "title": "Active Tracks",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "hrafnsyn_tracks_active_planes{instance=~\"$instance\"}", "legendFormat": "" }],
      "title": "Aircraft",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "hrafnsyn_tracks_active_vessels{instance=~\"$instance\"}", "legendFormat": "" }],
      "title": "Vessels",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "hrafnsyn_sources_enabled_total{instance=~\"$instance\"}", "legendFormat": "Enabled" },
        { "expr": "hrafnsyn_sources_configured_total{instance=~\"$instance\"}", "legendFormat": "Configured" }
      ],
      "title": "Feeds",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 200,
      "title": "Collectors and Ingest",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineInterpolation": "smooth" } } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "id": 10,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        { "expr": "sum by (result) (rate(hrafnsyn_collector_polls_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "{{result}}" }
      ],
      "title": "Collector Polls / sec",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }, "unit": "s" } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "id": 11,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(hrafnsyn_collector_poll_duration_seconds_bucket{instance=~\"$instance\"}[$__rate_interval])))",
          "legendFormat": "p95"
        }
      ],
      "title": "Collector Poll Duration",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineInterpolation": "smooth" } } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "id": 12,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        { "expr": "sum(rate(hrafnsyn_ingest_observations_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "Observations / sec" },
        { "expr": "sum(rate(hrafnsyn_ingest_tracks_touched_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "Touched tracks / sec" }
      ],
      "title": "Ingest Throughput",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 300,
      "title": "Runtime",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }, "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "id": 20,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [{ "expr": "hrafnsyn_prom_ex_beam_memory_allocated_bytes{instance=~\"$instance\"}", "legendFormat": "Allocated" }],
      "title": "BEAM Memory",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineInterpolation": "smooth" } } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "id": 21,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [{ "expr": "hrafnsyn_prom_ex_beam_stats_process_count{instance=~\"$instance\"}", "legendFormat": "Processes" }],
      "title": "BEAM Processes",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineInterpolation": "smooth" } } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "id": 22,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [{ "expr": "hrafnsyn_track_points_total{instance=~\"$instance\"}", "legendFormat": "Track points" }],
      "title": "Logged History Size",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 41,
  "style": "dark",
  "tags": ["hrafnsyn", "tracking", "ads-b", "ais"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      },
      {
        "current": { "selected": true, "text": "All", "value": ".*" },
        "hide": 0,
        "includeAll": true,
        "label": "Instance",
        "name": "instance",
        "options": [],
        "query": "label_values(hrafnsyn_tracks_active_total, instance)",
        "refresh": 2,
        "regex": "",
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Hrafnsyn Overview",
  "uid": "hrafnsyn-overview",
  "version": 1
}
