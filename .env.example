# Hrafnsyn reads these values directly from the shell environment.
# The repo .envrc loads .env and .env.local through direnv, so copy this file
# to .env.local and run `direnv reload`:
#   cp .env.example .env.local
#   direnv reload

# Switch local development out of anonymous readonly mode.
HRAFNSYN_PUBLIC_READONLY=false

# Bootstrap a known local admin user for username/password login.
# Username: admin
# Password: change-me-now
# Passwords must be at least 12 characters long.
HRAFNSYN_BOOTSTRAP_USERS_JSON='{"admin":{"password":"change-me-now","email":"admin@example.com","is_admin":true}}'
